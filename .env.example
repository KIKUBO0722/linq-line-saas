# Database
DATABASE_URL=postgresql://line_saas:line_saas_dev@localhost:5432/line_saas

# Redis
REDIS_URL=redis://localhost:6379

# LINE Messaging API
LINE_CHANNEL_ID=your_channel_id
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token

# Encryption (for storing LINE credentials)
ENCRYPTION_KEY=generate-a-32-byte-hex-key-here

# Auth
SESSION_SECRET=generate-a-random-string-here

# Google OAuth (optional — SSO login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# LINE Login (optional — SSO login)
LINE_LOGIN_CHANNEL_ID=your_line_login_channel_id
LINE_LOGIN_CHANNEL_SECRET=your_line_login_channel_secret

# OAuth callback base URL (API domain, used for redirect URIs)
OAUTH_CALLBACK_BASE_URL=http://localhost:3601

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# App
API_PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
NODE_ENV=development
